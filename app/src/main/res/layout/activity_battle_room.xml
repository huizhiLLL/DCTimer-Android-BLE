<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layout_battle_room"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    tools:context=".activity.BattleRoomActivity">

    <com.dctimer.widget.CustomToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?android:attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:theme="@style/AppTheme.NoActionBar"
        app:contentInsetStartWithNavigation="0dp"
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <RelativeLayout
        android:id="@+id/layout_room_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colorBackground">

        <LinearLayout
        android:id="@+id/ll_room_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="16dp"
        android:paddingTop="8dp"
        android:paddingRight="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <TextView
            android:id="@+id/tv_room_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/colorText"
            android:textSize="16sp" />

                <TextView
                    android:id="@+id/tv_room_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@drawable/button_text_style"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_room_round"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#757575"
                android:textSize="13sp" />
        </LinearLayout>



        <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_room_scramble"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/ll_room_header"
        android:gravity="center"
        android:lineSpacingMultiplier="1.3"
        android:paddingLeft="16dp"
        android:paddingTop="32dp"
        android:paddingRight="16dp"
        android:paddingBottom="32dp"
        android:textColor="@color/colorText" />

        <TextView
        android:id="@+id/tv_room_timer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/ll_room_header"
        android:gravity="center"
        android:textColor="@color/colorText"
        android:textSize="72sp" />

        <LinearLayout
        android:id="@+id/ll_room_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginBottom="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="0"
                android:background="@color/colorGray1"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                android:id="@+id/tv_room_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/colorText"
                android:textSize="14sp"
                android:paddingLeft="2dp"
                android:paddingRight="2dp" />

                <TextView
                    android:id="@+id/tv_room_summary_times"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:textColor="#757575"
                    android:textSize="12sp"
                    android:paddingLeft="2dp"
                    android:paddingRight="2dp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/iv_room_chevron"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginLeft="8dp"
                android:src="@drawable/ic_arrow_up"
                android:tint="#999999" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="0"
                android:background="@color/colorGray1"
                android:visibility="gone" />
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>
